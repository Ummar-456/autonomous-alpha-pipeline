# ── Autonomous Alpha Pipeline — Environment Configuration ─────────────────────
#
# Copy this file to .env and fill in your values.
# The pipeline runs in mock mode (no real LLM calls) if ANTHROPIC_API_KEY is unset.

# Required for live LLM decisions in the Decision Agent.
# Without this, the fallback CANCEL_ALL path is exercised on every alert.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional overrides (all have sensible defaults in OrchestratorConfig)
# BTCUSDT_WS_ENDPOINT=ws://localhost:8765
# LOB_DEPTH=20
# ALERT_QUEUE_MAXSIZE=100
# LLM_TIMEOUT_MS=500
# PROMETHEUS_PORT=8000
