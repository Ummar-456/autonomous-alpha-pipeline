{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Autonomous Alpha Pipeline — real-time SRE + business value telemetry",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🟢 Pipeline Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Packet Drop Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(pipeline_packets_dropped_total[1m]) / rate(pipeline_packets_received_total[1m])",
          "legendFormat": "drop rate"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Pipeline P99 Latency",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(pipeline_graph_latency_ms_bucket[5m]))",
          "legendFormat": "p99 ms"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Alert Queue Depth",
      "type": "stat",
      "targets": [
        {
          "expr": "pipeline_alert_queue_depth",
          "legendFormat": "queue depth"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "WS Reconnects (total)",
      "type": "stat",
      "targets": [
        {
          "expr": "pipeline_ws_reconnects_total",
          "legendFormat": "reconnects"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.3 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "LLM Fallback Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(pipeline_llm_fallbacks_total[5m]) / rate(pipeline_graph_invocations_total[5m])",
          "legendFormat": "fallback rate"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📊 Throughput & Latency",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" }, "tooltip": { "mode": "multi" } },
      "title": "Message Throughput (msg/s)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(pipeline_packets_received_total[30s])",
          "legendFormat": "packets received/s"
        },
        {
          "expr": "rate(pipeline_alerts_emitted_total[30s])",
          "legendFormat": "alerts emitted/s"
        },
        {
          "expr": "rate(pipeline_graph_invocations_total[30s])",
          "legendFormat": "graph invocations/s"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max", "p99"], "displayMode": "table" } },
      "title": "End-to-End Latency Percentiles",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(pipeline_graph_latency_ms_bucket[1m]))",
          "legendFormat": "p50 latency"
        },
        {
          "expr": "histogram_quantile(0.95, rate(pipeline_graph_latency_ms_bucket[1m]))",
          "legendFormat": "p95 latency"
        },
        {
          "expr": "histogram_quantile(0.99, rate(pipeline_graph_latency_ms_bucket[1m]))",
          "legendFormat": "p99 latency"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" } },
      "title": "LLM Decision Latency (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(pipeline_llm_latency_ms_bucket[1m]))",
          "legendFormat": "LLM p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(pipeline_llm_latency_ms_bucket[1m]))",
          "legendFormat": "LLM p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(pipeline_llm_latency_ms_bucket[1m]))",
          "legendFormat": "LLM p99"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "id": 13,
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"] } },
      "title": "Packet Drop Rate Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(pipeline_packets_dropped_total[1m])",
          "legendFormat": "drops/s"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "💼 Business Value",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 21 },
      "id": 20,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Total Analyst Hours Saved",
      "type": "stat",
      "targets": [
        {
          "expr": "pipeline_analyst_hours_saved_total",
          "legendFormat": "hours saved"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 21 },
      "id": 21,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Total Alerts Processed",
      "type": "stat",
      "targets": [
        {
          "expr": "pipeline_graph_invocations_total",
          "legendFormat": "invocations"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "h", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "id": 22,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "lastNotNull"] } },
      "title": "Analyst Hours Saved Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "pipeline_analyst_hours_saved_total",
          "legendFormat": "cumulative hours saved"
        },
        {
          "expr": "rate(pipeline_analyst_hours_saved_total[5m]) * 3600",
          "legendFormat": "hours saved/hour (rate)"
        }
      ]
    }

  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["alpha-pipeline", "microstructure", "sre"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Autonomous Alpha Pipeline",
  "uid": "alpha-pipeline-v1",
  "version": 1
}
